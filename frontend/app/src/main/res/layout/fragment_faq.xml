<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#FFFFFF">

    <!-- ScrollView MUST have ONE child -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">


        <!-- ================= FAQ SECTION ================= -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- FAQ TITLE -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="FAQ"
                android:textSize="36sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:fontFamily="@font/montserrat_extrabold"
                android:gravity="center"
                android:paddingBottom="24dp"
                android:layout_marginTop="40dp"/>

            <!-- ================= FAQ ITEM ================= -->
            <LinearLayout
                android:id="@+id/layoutQuestion1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#F5F5F5"
                android:padding="16dp"
                android:layout_marginBottom="5dp">

                <!-- QUESTION ROW -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/tvQuestion1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="How to use the app?"
                        android:textSize="15sp"
                        android:textColor="#000000"
                        android:fontFamily="@font/montserrat_bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/arrowIcon1"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"/>

                    <ImageView
                        android:id="@+id/arrowIcon1"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/arrow_down"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"/>
                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- ANSWER (HIDDEN BY DEFAULT) -->
                <TextView
                    android:id="@+id/tvAnswer1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:justificationMode="inter_word"
                    android:text="Capture the image of the waste. Let the system analyze the material. Identify the classification. Learn and recycle."
                    android:textSize="15sp"
                    android:textColor="#555555"
                    android:visibility="gone"
                    android:paddingTop="12dp"/>

            </LinearLayout>

            <!-- Add more FAQ items here by copying the block above -->
            <!-- ================= FAQ ITEM ================= -->
            <LinearLayout
                android:id="@+id/layoutQuestion2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#F5F5F5"
                android:padding="16dp"
                android:layout_marginBottom="5dp">

                <!-- QUESTION ROW -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/tvQuestion2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="How does the app works?"
                        android:textSize="15sp"
                        android:textColor="#000000"
                        android:fontFamily="@font/montserrat_bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/arrowIcon2"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"/>

                    <ImageView
                        android:id="@+id/arrowIcon2"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/arrow_down"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"/>
                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- ANSWER (HIDDEN BY DEFAULT) -->
                <TextView
                    android:id="@+id/tvAnswer2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:justificationMode="inter_word"
                    android:text="Capture a photo of any material. The system analyzes the image using AI-based classification. It identifies the type of material (plastic, paper, glass, metal, etc.) and tells you if it’s recyclable. The app also provides recycling tips and disposal guidance."
                    android:textSize="15sp"
                    android:textColor="#555555"
                    android:visibility="gone"
                    android:paddingTop="12dp"/>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</ScrollView>
