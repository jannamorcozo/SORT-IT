MODEL_URL_STAGE3_PLASTIC=
MODEL_URL_STAGE3_PAPER=
MODEL_URL_STAGE3_METAL=
MODEL_URL_STAGE3_GLASS=
MODEL_URL_STAGE3_RESIDUAL=
